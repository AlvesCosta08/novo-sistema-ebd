# ============================================
# CONFIGURAÇÕES DO SISTEMA EBD
# ============================================

APP_ENV=production
APP_DEBUG=false
APP_VERSION=3.0.0

# ============================================
# CONFIGURAÇÕES DO BANCO DE DADOS
# ============================================
# 🔐 Preencha com as credenciais do seu servidor

DB_HOST=seu_host
DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASS=sua_senha
DB_PORT=3306
DB_CHARSET=utf8mb4

# ============================================
# CONFIGURAÇÕES DO SERVIDOR
# ============================================

BASE_URL=https://seu-dominio.com/sistemas/escola
ROOT_PATH=/caminho/para/o/projeto

# ============================================
# CHAVE DE SEGURANÇA (gerar uma única)
# ============================================
# Execute: php -r "echo bin2hex(random_bytes(32));"

APP_KEY=gerar-uma-chave-unica-aqui